{
  "name": "anime1-desktop-electron",
  "productName": "Anime1Desktop",
  "version": "0.3.6",
  "description": "Anime1 Desktop - Electron + TypeScript 重构版",
  "main": "dist-electron/main/index.js",
  "author": "elfgzp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elfgzp/anime1-desktop.git"
  },
  "homepage": "https://github.com/elfgzp/anime1-desktop#readme",
  "build": {
    "appId": "com.elfgzp.anime1-desktop",
    "productName": "Anime1Desktop",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "resources",
      "!**/*.map"
    ],
    "asar": true,
    "asarUnpack": [
      "resources/**"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.entertainment",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "icon": "resources/icon.ico"
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "AudioVideo",
      "target": [
        "AppImage",
        "tar.gz"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "elfgzp",
      "repo": "anime1-desktop"
    }
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/verify-preload.cjs && vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:fast": "vite build && electron-builder",
    "build:mac": "vue-tsc --noEmit && vite build && electron-builder --mac",
    "build:mac:fast": "vite build && electron-builder --mac",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "build:win:fast": "vite build && electron-builder --win",
    "build:linux": "vue-tsc --noEmit && vite build && electron-builder --linux",
    "build:linux:fast": "vite build && electron-builder --linux",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test smoke.spec.ts",
    "test:e2e:report": "playwright show-report e2e-report",
    "test:e2e:check": "npx ts-node e2e/check-env.ts",
    "test:e2e:sanity": "playwright test sanity.spec.ts",
    "test:e2e:fast": "playwright test -c playwright.shared.config.ts --reporter=line"
  },
  "dependencies": {
    "@libsql/darwin-arm64": "^0.5.22",
    "@types/dompurify": "^3.0.5",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.10",
    "date-fns": "^3.3.1",
    "dompurify": "^3.3.1",
    "electron-log": "^5.1.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.8",
    "electron-vite": "^5.0.0",
    "element-plus": "^2.13.2",
    "hls.js": "^1.5.7",
    "libsql": "^0.5.3",
    "lodash-es": "^4.17.21",
    "opencc-js": "^1.0.5",
    "pinia": "^2.1.7",
    "vue": "^3.4.19",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.20",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "electron": "^40.4.0",
    "electron-builder": "^24.12.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.2.5",
    "rollup": "^4.57.1",
    "typescript": "^5.9.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
